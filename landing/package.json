    "@vueuse/nuxt": "^10.11.1",
    "nuxt": "^3.21.6",
    "nuxt-icon": "^0.6.10",
    "pinia": "^3.0.4",
    "swiper": "^12.1.2",
    "vue": "^3.5.27",
    "vue-i18n": "^11.2.8",
